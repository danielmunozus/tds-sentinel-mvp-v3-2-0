# .env.example — TDS Sentinel API
# ─────────────────────────────────────────────────────────────
# INSTRUCCIONES:
#   1. Copia este archivo como .env en la carpeta backend/
#      cp .env.example .env
#   2. Completa los valores reales en .env
#   3. NUNCA subas .env a git (ya está en .gitignore)
# ─────────────────────────────────────────────────────────────

# ── Flask ─────────────────────────────────────────────────────
# Activa modo debug (true solo en desarrollo local, NUNCA en producción)
FLASK_DEBUG=true

# Clave secreta para firmar sesiones y tokens.
# Genera una segura con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REEMPLAZA_CON_UN_VALOR_SECRETO_SEGURO

# Puerto de la aplicación
PORT=5000

# ── Base de datos ─────────────────────────────────────────────
# Ruta al archivo SQLite. Si se omite, se usa la ruta por defecto.
# DB_PATH=/ruta/absoluta/a/sentinel.db

# ── Sesiones ──────────────────────────────────────────────────
# Duración de los tokens Bearer en horas (default: 24).
# SESSION_HOURS=24

# ── CORS ──────────────────────────────────────────────────────
# Orígenes permitidos, separados por coma.
# Desarrollo local Flutter (iOS/Android en emulador puede necesitar ajuste):
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000